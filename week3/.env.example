# Required: GitHub OAuth App credentials
# Create an OAuth App at https://github.com/settings/developers
# Set Authorization callback URL to http://localhost:8000/oauth/callback
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Required: must match the Authorization callback URL in your GitHub OAuth App
REDIRECT_URI=http://localhost:8000/oauth/callback

# Optional: port the server listens on (default: 8000)
PORT=8000
